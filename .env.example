# Base de datos PostgreSQL / Neon
# Obtén tu URL de conexión desde tu proveedor de BD
# Formato: postgresql://usuario:contraseña@host:puerto/base_datos
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/caja_entradas

# Secreto para JWT - CAMBIAR EN PRODUCCIÓN
# Generar con: openssl rand -base64 32
JWT_SECRET=dev-secret-key-change-in-production-with-openssl-rand

# Entorno
NODE_ENV=development

# Puerto (opcional, por defecto 5173)
# PORT=5173

# NOTA: Este archivo es un ejemplo. Copia a .env.local y actualiza los valores.
# NUNCA commites .env.local a git
